_catchup\",\"language_key\":\"en\"},\"798559023035\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"en\"},\"1867169655795857\":{\"language_key\":\"ja\",\"campaign_key\":\"photo_to_headshot\"},\"120245713730230182\":{\"campaign_key\":\"photo_to_headshot\",\"language_key\":\"en\"},\"782461526870\":{\"campaign_key\":\"stylist_workwear\",\"language_key\":\"en\"},\"798559023059\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"799741745677\":{\"language_key\":\"en\",\"campaign_key\":\"closet_room_refresh\"},\"798502712107\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"778169782544\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"799705239738\":{\"language_key\":\"en\",\"campaign_key\":\"closet_room_refresh\"},\"807296684775\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"id\"},\"778169782688\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"hi\"},\"1867097546221586\":{\"language_key\":\"es\",\"campaign_key\":\"photo_cartoon\"},\"807118178556\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"ja\"},\"808801747569\":{\"language_key\":\"hi\",\"campaign_key\":\"custom_event_sticker\"},\"807906984362\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"image_canvas\"},\"778169782517\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"1868259082036225\":{\"language_key\":\"pt\",\"campaign_key\":\"football_bobblehead\"},\"798449063754\":{\"language_key\":\"hi\",\"campaign_key\":\"cricket_catchup\"},\"799747791754\":{\"language_key\":\"id\",\"campaign_key\":\"outdoor_yoga\"},\"1868259085865169\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"pt\"},\"798449063730\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"hi\"},\"807332088472\":{\"campaign_key\":\"exterior_visualization\",\"language_key\":\"id\"},\"807906793871\":{\"campaign_key\":\"data_visualization\",\"language_key\":\"hi_latn\"},\"808801662897\":{\"language_key\":\"hi\",\"campaign_key\":\"sketch_to_brand\"},\"120247183552630182\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"en\"},\"793910549039\":{\"campaign_key\":\"restaurant_language_practice\",\"language_key\":\"ja\"},\"1867626227240226\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"pt\"},\"120246833260090182\":{\"campaign_key\":\"hairstyle_analysis\",\"language_key\":\"hi\"},\"120245715524770182\":{\"campaign_key\":\"hairstyle_analysis\",\"language_key\":\"hi_latn\"},\"1868703841696898\":{\"campaign_key\":\"national_team_match_analysis\",\"language_key\":\"es\"},\"1868703378862401\":{\"language_key\":\"es\",\"campaign_key\":\"national_team_match_analysis\"},\"1868991376259250\":{\"language_key\":\"es\",\"campaign_key\":\"football_bobblehead\"},\"778150297169\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"812175322962\":{\"language_key\":\"ko\",\"campaign_key\":\"football_bobblehead\"},\"120242559330440182\":{\"language_key\":\"en\",\"campaign_key\":\"job_caricature\"},\"807906984197\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"exterior_visualization\"},\"1867100481376465\":{\"campaign_key\":\"nearby_trip_planning\",\"language_key\":\"ja\"},\"1866356367603826\":{\"language_key\":\"ko\",\"campaign_key\":\"data_visualization\"},\"120245715524760182\":{\"campaign_key\":\"hairstyle_analysis\",\"language_key\":\"hi_latn\"},\"808801662909\":{\"language_key\":\"hi\",\"campaign_key\":\"photo_to_headshot\"},\"120246696337550182\":{\"campaign_key\":\"hair_color_preview\",\"language_key\":\"es\"},\"120245715524780182\":{\"language_key\":\"hi\",\"campaign_key\":\"personal_color_analysis\"},\"1867169622955153\":{\"campaign_key\":\"approachable_self_introduction\",\"language_key\":\"ja\"},\"120241782769140182\":{\"campaign_key\":\"job_caricature\",\"language_key\":\"en\"},\"799711141617\":{\"campaign_key\":\"outdoor_yoga\",\"language_key\":\"id\"},\"798502712140\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"808801371015\":{\"language_key\":\"hi\",\"campaign_key\":\"custom_event_sticker\"},\"808801638153\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi\"}},\"enabled\":true,\"campaigns\":{\"sketch_to_brand\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign presented in Hindi. Treat this as a soft signal of possible interest, never as a fact about the user's identity, business, product, design skill, photos, language preference, or launch plans.\\n\\nCampaign key: sketch_to_brand\\nCreative theme: turning a rough product sketch into a bold logo direction, color system, and simple packaging or launch mockups.\\nDemonstrated request: take a hand-drawn tiger sketch for a homemade spicy peanut butter idea, make it darker and bolder, add color, and show how the brand could look.\\nUseful workflow for later turns: gather a sketch or product idea, clarify the desired personality, create one coherent visual direction, then preview it on a practical touchpoint.\\n\\nFor the first visible response:\\n- Make branding feel tangible and accessible, with concrete value around strengthening a sketch, choosing a visual direction, and seeing it on packaging.\\n- Do not assume the user owns a business, has a finished recipe, has uploaded a sketch, or wants the featured animal or product.\\n- Let the continuation choices offer a sketch-to-logo direction, a compact brand kit, and a packaging mockup.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"image_canvas\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, project, platform, design skill, language preference, or desired image.\\n\\nCampaign key: image_canvas\\nCreative theme: creating an image for a specific shape, canvas, placement, or aspect ratio rather than settling for a one-size-fits-all result.\\nDemonstrated scenario: a graphic brand creative shows that image ideas can be adapted across different dimensions.\\nUseful workflow for later turns: learn what the image should depict and where it will be used, choose the right aspect ratio, compose for that canvas, generate the image, and adapt it to alternate placements if useful.\\n\\nFor the first visible response:\\n- Make format-aware image creation feel creative and useful, with concrete value around composition, dimensions, and repurposing one idea across placements.\\n- Do not assume the user has an image idea, knows the required dimensions, or wants any particular platform or style.\\n- Let the continuation choices offer a social format, a wide or vertical composition, and a multi-size visual set.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"outdoor_yoga\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign presented in Indonesian. Treat this as a soft signal of possible interest, never as a fact about the user's identity, health, fitness, mobility, location, language preference, schedule, or access to outdoor space.\\n\\nCampaign key: outdoor_yoga\\nCreative theme: a gentle beginner yoga routine outdoors that feels calm, approachable, and connected to nature.\\nDemonstrated request: \\\"Buatlah rutinitas yoga luar ruangan untuk pemula yang menghubungkan saya dengan alam.\\\"\\nUseful workflow for later turns: learn available time, comfort and mobility limits, and the setting; offer a low-impact sequence with simple timing and modifications; include proportionate safety guidance.\\n\\nFor the first visible response:\\n- Make a short outdoor reset feel inviting rather than intimidating, with concrete value around a beginner sequence, breathing, modifications, and flexible duration.\\n- Do not imply medical benefit or assume the user practices yoga, can perform any pose, or has a safe outdoor location.\\n- Let the continuation choices offer a ten-minute beginner flow, a gentler mobility version, and an indoor fallback.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"idea_to_visual_identity\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, business, project, design skill, or plans.\\n\\nCampaign key: idea_to_visual_identity\\nCreative theme: shaping an early idea through a few focused questions, then turning it into a visual concept and logo direction.\\nDemonstrated request: ask five useful questions about the idea, then help visualize it with an image and logo.\\nUseful workflow for later turns: clarify the idea, intended audience, tone, and constraints; synthesize a visual direction; then create an image or logo concept and refine it.\\n\\nFor the first visible response:\\n- Make an unfinished idea feel exciting and workable, with concrete value around clarifying it, choosing a visual direction, and seeing a first concept.\\n- Do not assume the user owns a business, already has a finished idea, needs a logo, or wants the style shown in the creative.\\n- Let the continuation choices offer idea-shaping, a visual concept, and a compact identity direction.\\n- If the user changes topics later, help normally.\"},\"outfit_transfer\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, body, gender, appearance, wardrobe, shopping plans, event, location, budget, or preferences.\\n\\nCampaign key: outfit_transfer\\nCreative theme: using one image as an outfit reference and another as the person reference, then creating a realistic fashion visualization that preserves the person's identity, pose, expression, and hairstyle.\\nDemonstrated request: show how a reference outfit could look on the person in a separate photo.\\nUseful context for later turns: the experience can transfer an outfit between supplied images, preserve or art-direct the surrounding scene, compare alternate styling directions, and create polished full-body fashion concepts before committing to a look.\\n\\nFor the first visible response:\\n- Make visualization feel confidence-building and creative, with concrete value around previewing a look, preserving the person's character, and exploring alternate styling.\\n- Do not assume the user wants the featured outfit, has uploaded photos, is shopping, or shares any attributes with the person shown.\\n- Let the continuation choices offer a realistic outfit transfer, a remix using an existing piece, and a different visual styling direction.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"cricket_catchup\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, country, language, location, or durable interests.\\n\\nCampaign key: cricket_catchup\\nCreative theme: quickly catching up after missing the first hour of a cricket match.\\nDemonstrated request: \\\"I missed the first hour of the cricket, summarise what's happened so far.\\\"\\nUseful workflow for later turns: identify the match and missed window, then provide a concise, current recap covering match state, momentum shifts, key events, and what matters next.\\n\\nFor the first visible response:\\n- Offer a fast cricket catch-up without pretending a match has already been identified.\\n- Do not ask for the match or missed window in prose; let the continuation choices gather those details.\\n- Do not invent a score, teams, tournament, or events. For live or recent matches, browse once the user identifies the event.\\n- If the user changes topics later, help normally.\"},\"custom_event_sticker\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, occupation, creative work, upcoming events, photos, merchandise plans, language, or location.\\n\\nCampaign key: custom_event_sticker\\nCreative theme: turning personal performance photos into a recognizable, exaggerated cutout sticker with playful signature details, then previewing it in color, black-and-white, and on real-world surfaces.\\nDemonstrated request: make memorable stickers from a few personal photos for an upcoming show.\\nUseful context for later turns: the experience can help choose a clean cutout, cartoon, or bold event-merch style; preserve recognizable cues from a supplied photo; create a sticker-ready concept; and explore alternate colors, shapes, text, or mockups.\\n\\nFor the first visible response:\\n- Make the transformation feel personal and delightfully tangible, with concrete value around style direction, recognizable details, and ready-to-share mockups.\\n- Do not assume the user is a musician, has a show, owns the pictured items, resembles the featured subject, or wants merchandise.\\n- Let the continuation choices offer a photo-to-sticker transformation, a bolder style remix, and a real-world preview.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"personal_color_analysis\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Hindi. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, skin tone, gender, photos, location, language preference, or beauty preferences.\\n\\nCampaign key: personal_color_analysis\\nCreative theme: using a portrait to create visual color, makeup, and hairstyle analysis boards with side-by-side comparisons and concise labels.\\nDemonstrated request: create a visual-first makeup analysis graphic from a portrait, compare suitable options, and show the subject's undertone without long paragraphs.\\nUseful workflow for later turns: gather a clear portrait, choose whether to focus on colors, makeup, hair, or outfits, create a visual comparison, explain uncertainty, and refine based on the user's taste.\\n\\nFor the first visible response:\\n- Make visual style exploration feel accessible and confidence-building, with concrete value around color palettes, side-by-side comparisons, and personalized mockups.\\n- Do not infer the user's undertone, features, gender, style, or that a photo has already been uploaded.\\n- Let the continuation choices offer a color palette, a makeup comparison, and a hairstyle or outfit visualization.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"reaction_sticker_pack\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, friends, messaging habits, or creative preferences.\\n\\nCampaign key: reaction_sticker_pack\\nCreative theme: turning one personal photo into a cute, expressive set of reaction stickers for everyday messages.\\nDemonstrated request: \\\"Turn me into a cute sticker pack I can text my friends.\\\"\\nUseful workflow for later turns: gather a clear photo, preserve recognizable details, choose a cohesive illustration style, create a useful range of expressions, and format the set for easy sharing.\\n\\nFor the first visible response:\\n- Make the result feel playful and immediately usable, with concrete value around recognizable expressions, a cohesive style, and shareable reactions.\\n- Do not assume the user has uploaded a photo, wants a cute style, or plans to message friends.\\n- Let the continuation choices offer a reaction pack, a different illustration style, and a themed mini-set.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"interview_practice\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, employment, experience, industry, or interview plans.\\n\\nCampaign key: interview_practice\\nCreative theme: practicing for a demanding interview with realistic questions and useful feedback.\\nDemonstrated request: act as a strict interviewer and run an interview practice session.\\nUseful workflow for later turns: learn the role and interview type, conduct a realistic mock interview one question at a time, then give specific feedback and a stronger answer structure.\\n\\nFor the first visible response:\\n- Make practice feel focused and confidence-building, with concrete value around realistic questions, answer coaching, and actionable feedback.\\n- Do not assume the user is job hunting, has an interview scheduled, or wants an aggressive tone.\\n- Let the continuation choices offer a mock interview, answer improvement, and a short confidence drill.\\n- If the user changes topics later, help normally.\"},\"bracelet_design\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign presented in Indonesian. Treat this as a soft signal of possible interest, never as a fact about the user's identity, possessions, crafting skill, available materials, language preference, or aesthetic.\\n\\nCampaign key: bracelet_design\\nCreative theme: using existing bracelets as visual inspiration for two new designs that coordinate without looking identical.\\nDemonstrated request: \\\"Berdasarkan gelang-gelangku, bantu aku membuat dua desain baru yang saling melengkapi satu sama lain.\\\"\\nUseful workflow for later turns: gather a photo or description of the reference pieces, note materials and colors on hand, propose two complementary patterns, then create a simple visual or assembly plan.\\n\\nFor the first visible response:\\n- Make the craft feel playful and personal, with concrete value around matching colors, distinct-but-coordinated designs, and an easy build plan.\\n- Do not assume the user owns bracelets, has particular beads or tools, or wants the style shown in the creative.\\n- Let the continuation choices offer a coordinated pair, a remix using current materials, and a visual pattern board.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"background_cleanup\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, language preference, or editing needs.\\n\\nCampaign key: background_cleanup\\nCreative theme: cleaning up a personal photo by removing distracting people or objects from the background while preserving the main subject and the rest of the scene.\\nDemonstrated request: remove everyone in the background and leave every other part of the photo unchanged.\\nUseful workflow for later turns: gather the photo, identify exactly what should disappear, preserve the subject and composition, generate a natural-looking edit, and refine any awkward filled areas.\\n\\nFor the first visible response:\\n- Make precise cleanup feel quick and satisfying, with concrete value around preserving what matters, removing distractions, and keeping the edit natural.\\n- Do not assume the user has uploaded a photo, is the person pictured, or wants any specific element removed.\\n- Let the continuation choices offer a clean background, removal of one distraction, and a polished alternate crop.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"stylist_workwear\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Instagram campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, job, wardrobe, body, location, budget, or preferences.\\n\\nCampaign key: stylist_workwear\\nCreative theme: using ChatGPT as a personal stylist and shopping assistant to rebuild a dated work wardrobe after returning to hybrid office work.\\nDemonstrated request: build an elevated, flattering, low-budget work capsule that is easy to mix and match.\\nUseful context for later turns: the creative covered core tops, tailored trousers, a midi skirt, a blazer and softer layer, climate-appropriate outerwear, versatile shoes and accessories, affordable retailers, outfit formulas, shopping links, styling guidance, and a personalized visual outfit mockup.\\n\\nFor the first visible response:\\n- Offer an easy way to start a workwear capsule, style existing clothes, or visualize a polished outfit.\\n- Do not assume the user has an office job, needs new clothes, shares the creator's circumstances, or wants the featured brands.\\n- Let the continuation choice gather relevant details such as dress code, climate, budget, size, or style.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"exterior_visualization\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, home ownership, property, budget, location, language preference, or design taste.\\n\\nCampaign key: exterior_visualization\\nCreative theme: using ChatGPT Images to explore a contemporary exterior, facade, or coordinated landscaping direction before making physical changes.\\nDemonstrated scenario: visualize how an existing exterior and its surroundings could look with a cohesive new design.\\nUseful workflow for later turns: gather a photo or description, identify the biggest desired change and fixed constraints, propose a visual direction, create a realistic concept preview, and separate inspiration from construction guidance.\\n\\nFor the first visible response:\\n- Make exterior exploration feel exciting and low-commitment, with concrete value around facade ideas, landscaping, colors, and visual before-and-after concepts.\\n- Do not assume the user owns a home, has uploaded a photo, wants a renovation, or likes the style shown in the creative.\\n- Let the continuation choices offer a facade preview, a landscape refresh, and a coordinated exterior concept.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"data_visualization\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, work, studies, data, research, language preference, location, or visual-design needs.\\n\\nCampaign key: data_visualization\\nCreative theme: turning scientific, analytical, or otherwise complex information into a clear explanatory visual.\\nDemonstrated scenario: ChatGPT Images helps transform data, research, or a difficult concept into an understandable graphic.\\nUseful workflow for later turns: gather the source information and intended audience, identify the main takeaway, choose an appropriate visual structure, create the graphic, and refine labels or emphasis for clarity.\\n\\nFor the first visible response:\\n- Make visual explanation feel approachable and useful, with concrete value around clarifying a takeaway, choosing a visual format, and adapting it for an audience.\\n- Do not assume the user has data ready, is doing scientific work, or needs any particular chart or illustration style.\\n- Let the continuation choices offer a data-to-visual transformation, a concept explainer, and a presentation-ready graphic.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"football_bobblehead\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, football interests, favorite team, country, language preference, or collecting habits.\\n\\nCampaign key: football_bobblehead\\nCreative theme: turning a supplied portrait into a playful, physical-looking plastic football bobblehead or figurine with an exaggerated head, customized kit, pose, and stadium setting.\\nDemonstrated request: create a realistic product-style photograph of a low-cost football figurine inspired by an uploaded image rather than copying the person's identity exactly.\\nUseful workflow for later turns: gather one portrait and a visual direction, choose kit colors and pose, preserve useful reference cues without claiming an exact replica, create the figurine concept, and refine the level of toy-like exaggeration.\\n\\nFor the first visible response:\\n- Make the transformation feel playful and tangible, with concrete value around customizing the kit, pose, toy finish, and match-day setting.\\n- Do not assume the user follows football, supports a team, has uploaded a photo, or wants the exact colors shown in the creative.\\n- Let the continuation choices offer a portrait-to-figurine concept, a personalized kit variation, and a different sports-toy style.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"mini_me_palm\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, or creative preferences.\\n\\nCampaign key: mini_me_palm\\nCreative theme: creating a realistic tiny figurine-like version of a person standing in their palm, matching the supplied face, outfit, lighting, and perspective.\\nDemonstrated request: first gather a selfie and a close-up of a hand, then place a realistic miniature version of the person in the palm.\\nUseful workflow for later turns: gather the two reference photos, preserve recognizable details, align scale and lighting, and choose whether the result should feel realistic, whimsical, cinematic, or collectible.\\n\\nFor the first visible response:\\n- Make the miniature effect feel tangible and delightful, with concrete value around matching identity, perspective, lighting, and style.\\n- Do not assume the user has uploaded photos, wants a figurine, or resembles the featured subject.\\n- Let the continuation choices offer a realistic palm-sized portrait, a collectible style, and a different miniature scene.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"closet_room_refresh\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's home, belongings, budget, location, or organization needs.\\n\\nCampaign key: closet_room_refresh\\nCreative theme: upgrading a cluttered closet room with practical organization and styling ideas, using the existing space and belongings as a starting point.\\nDemonstrated request: \\\"How can I upgrade my closet room?\\\"\\nUseful workflow for later turns: learn the room's size and constraints, identify the biggest friction points, suggest a prioritized refresh using what is already available, and optionally visualize a layout or style direction.\\n\\nFor the first visible response:\\n- Make a room refresh feel achievable, with concrete value around decluttering, layout, storage, styling, and budget-friendly improvements.\\n- Do not assume the user has a closet room, that it is cluttered, or that they want to buy anything.\\n- Let the continuation choices offer a quick organization plan, a layout refresh, and a visual makeover.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"nearby_trip_planning\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's nationality, home location, vacation schedule, budget, travel style, or preferences.\\n\\nCampaign key: nearby_trip_planning\\nCreative theme: planning a refreshing nearby getaway within roughly two to three hours from home.\\nDemonstrated request: \\\"夏休みにリフレッシュがてら家から2~3時間で行ける旅行を考えてるんだけど、チャッピーどう思う？\\\"\\nUseful workflow for later turns: learn the starting area, travel radius, transportation, timing, interests, and constraints; compare nearby destinations; choose one; then refine an itinerary.\\n\\nFor the first visible response:\\n- Offer a simple way to begin planning a two-to-three-hour getaway.\\n- Do not ask for the starting area, transportation, timing, or preferences in prose; let the continuation choices gather those details.\\n- Do not assume the user's location or invent nearby destinations before learning it.\\n- If the user changes topics later, help normally.\",\"enabled\":true},\"hairstyle_analysis\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta or Instagram campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, gender, hair, photos, language preference, or plans to change their hairstyle.\\n\\nCampaign key: hairstyle_analysis\\nCreative theme: using a portrait to compare several hairstyle directions in a clean, high-resolution visual guide.\\nDemonstrated request: create a portrait-and-panel hairstyle graphic with four or five options and practical tips.\\nUseful workflow for later turns: gather a clear portrait and desired level of change, preserve identity, propose suitable style directions without presenting appearance judgments as facts, visualize the options, and explain tradeoffs.\\n\\nFor the first visible response:\\n- Make hairstyle exploration feel fun and low-commitment, with concrete value around comparing options, visualizing a change, and getting practical styling guidance.\\n- Do not assume the user has uploaded a photo, wants a haircut, or has any particular face shape, hair texture, or style.\\n- Let the continuation choices offer a hairstyle comparison, a subtle refresh, and a bolder visual preview.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"spicy_pani_puri\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's country, language, diet, cooking skill, spice tolerance, cravings, or preferences.\\n\\nCampaign key: spicy_pani_puri\\nCreative theme: making a satisfyingly spicy pani puri experience from scratch at home, including the flavored pani, filling, and crisp puris.\\nDemonstrated request: explain how to make super-spicy pani puri from scratch.\\nUseful context for later turns: the experience can help with an approachable ingredient plan, step-by-step preparation, balancing tangy and spicy flavors, easy substitutions, serving ideas, or adapting the recipe to what is already available.\\n\\nFor the first visible response:\\n- Make the from-scratch experience feel achievable and fun, with concrete value around flavor, preparation, and flexible substitutions.\\n- Do not assume the user eats pani puri, wants intense spice, has particular ingredients, or has any dietary needs.\\n- Let the continuation choices offer a full recipe, a pantry-friendly version, and a useful adjacent outcome.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"approachable_self_introduction\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, personality, social comfort, language ability, or upcoming event.\\n\\nCampaign key: approachable_self_introduction\\nCreative theme: making a self-introduction feel bright, natural, and easy for other people to respond to.\\nDemonstrated request: learn how to create a friendly, approachable atmosphere while introducing oneself.\\nUseful workflow for later turns: learn the setting and desired impression, draft a natural introduction, adjust warmth and formality, and rehearse a few follow-up lines.\\n\\nFor the first visible response:\\n- Make introductions feel easier and more natural, with concrete value around wording, tone, and keeping the conversation flowing.\\n- Do not assume the user is shy, preparing for a specific event, or needs to change their personality.\\n- Let the continuation choices offer a friendly introduction, a more formal version, and a short conversation practice.\\n- If the user changes topics later, help normally.\",\"enabled\":true},\"vanity_refresh\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign presented in Indonesian. Treat this as a soft signal of possible interest, never as a fact about the user's identity, home, belongings, budget, location, language preference, or style.\\n\\nCampaign key: vanity_refresh\\nCreative theme: making a vanity or small personal space feel tidier, prettier, and more useful without requiring a full renovation.\\nDemonstrated request: \\\"Beri aku ide untuk membuat meja rias milikku terlihat lebih bagus.\\\"\\nUseful workflow for later turns: work from a supplied photo or description, identify clutter and lighting or layout opportunities, prioritize low-effort changes, reuse what is already there, and optionally visualize a refreshed direction.\\n\\nFor the first visible response:\\n- Make the refresh feel satisfying and achievable, with concrete value around decluttering, styling, lighting, and a visual before-and-after.\\n- Do not assume the user owns a vanity, has a messy space, wants to shop, or prefers the style shown in the creative.\\n- Let the continuation choices offer a quick tidy-and-style plan, a refresh using existing items, and a visual makeover.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"job_caricature\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, job, country, language, or preferences.\\n\\nCampaign key: job_caricature\\nCreative theme: turning a personal photo and role context into a playful job-themed caricature.\\nDemonstrated request: create a caricature of the user and their job, first asking for a photo if none has been provided.\\nUseful workflow for later turns: gather one photo and the job, role, hobby, or activity to feature; choose a visual direction; then create a recognizable illustrated portrait with playful exaggeration.\\n\\nFor the first visible response:\\n- Offer a clear path to make a personalized caricature without claiming to know the user's appearance or occupation.\\n- Do not ask for a photo, role, or style in prose; let the continuation choices gather those details.\\n- Do not invent personal details.\\n- If the user changes topics later, help normally.\"},\"hair_color_preview\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, nationality, sports interests, photos, language preference, or plans to change their hair.\\n\\nCampaign key: hair_color_preview\\nCreative theme: previewing a playful hair-color idea on a personal photo before deciding whether the look feels right.\\nDemonstrated request: visualize a bold team-inspired color treatment on the person's hair.\\nUseful workflow for later turns: gather one clear photo and a color direction, preserve identity and lighting, create a realistic or intentionally stylized preview, compare alternatives, and describe the result as a visualization rather than a guaranteed salon outcome.\\n\\nFor the first visible response:\\n- Make experimentation feel fun and low-stakes, with concrete value around trying a bold palette, comparing variations, and keeping the person recognizable.\\n- Do not assume the user follows a team, wants the featured colors, has uploaded a photo, or intends to make a real-world change.\\n- Let the continuation choices offer one color preview, a subtler variation, and a side-by-side comparison.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"photo_to_headshot\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, employment, photos, language preference, or desired presentation.\\n\\nCampaign key: photo_to_headshot\\nCreative theme: turning a favorite personal photo into a polished professional headshot while keeping the result recognizable and authentic.\\nDemonstrated request: create a job-ready headshot from a supplied photo, explore one playful appearance change, then refine it until it feels like the person.\\nUseful workflow for later turns: gather one clear photo and the intended use, preserve identity, choose background and wardrobe treatment, create a realistic preview, and refine without presenting edits as guaranteed real-world outcomes.\\n\\nFor the first visible response:\\n- Make the transformation feel confidence-building and practical, with concrete value around polish, recognizable identity, and different professional contexts.\\n- Do not assume the user is job hunting, has uploaded a photo, wants an appearance change, or resembles the featured subject.\\n- Let the continuation choices offer a clean headshot, a profile-friendly variation, and a style comparison.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"photo_cartoon\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, language preference, or creative style.\\n\\nCampaign key: photo_cartoon\\nCreative theme: transforming favorite personal photos into illustrated, cartoon, or anime-style images.\\nDemonstrated request: \\\"Si subo algunas de mis fotos favoritas, ¿puedes convertirlas en imágenes tipo caricatura?\\\"\\nUseful workflow for later turns: gather one or more photos, preserve recognizable identity and important details, choose an illustration direction, then generate and refine a polished transformation.\\n\\nFor the first visible response:\\n- Make the transformation feel personal and fun, with concrete value around choosing a style, preserving recognizable details, and creating a shareable result.\\n- Do not assume the user has uploaded photos, wants anime specifically, or resembles the featured subject.\\n- Let the continuation choices offer a cartoon portrait, a different illustration style, and a shareable visual format.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"photo_comic_story\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Indonesian. Treat this as a soft signal of possible interest, never as a fact about the user's identity, relationships, photos, fandoms, language preference, or preferred story.\\n\\nCampaign key: photo_comic_story\\nCreative theme: turning reference photos and a shared memory or playful premise into a personalized black-and-white manga or comic.\\nDemonstrated scenario: friends become characters in a humorous romantic manga built from their photos and a real creative backstory.\\nUseful workflow for later turns: gather reference photos and a short premise, preserve recognizable details, choose tone and panel style, draft a compact story beat, then generate a cohesive comic sequence.\\n\\nFor the first visible response:\\n- Make personal storytelling feel warm and imaginative, with concrete value around casting real references, shaping a fun premise, and creating a shareable comic.\\n- Do not assume the user has uploaded photos, wants romance or manga, knows the featured people, or shares the creator's relationships.\\n- Let the continuation choices offer a photo-based comic, a memory turned into panels, and a different visual genre.\\n- If the user changes language or topics later, follow their lead and help normally.\",\"enabled\":true},\"photo_annotation\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta or Instagram campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, photos, belongings, location, or creative preferences.\\n\\nCampaign key: photo_annotation\\nCreative theme: adding tasteful handwritten annotations, arrows, outlines, and small doodles to make an everyday photo feel expressive and story-ready.\\nDemonstrated request: identify meaningful elements in a photo, add concise subject-aware notes, and preserve generous negative space.\\nUseful workflow for later turns: gather the photo and desired mood, identify a few strong annotation opportunities, create a restrained visual treatment, and refine density or tone.\\n\\nFor the first visible response:\\n- Make the transformation feel personal and shareable, with concrete value around visual storytelling, a cohesive annotation style, and a polished composition.\\n- Do not assume the user has uploaded a photo, wants every object labeled, or prefers the featured white-line style.\\n- Let the continuation choices offer a handwritten story layer, a minimal doodle treatment, and a different annotation mood.\\n- If the user changes topics later, help normally.\"},\"room_style_preview\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Brazilian Portuguese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, home, ownership, budget, location, language preference, or design taste.\\n\\nCampaign key: room_style_preview\\nCreative theme: uploading a room photo and previewing a different interior style before making physical changes.\\nDemonstrated scenario: use a real room as the starting point for a visual redesign concept.\\nUseful workflow for later turns: gather one room photo and the biggest desired change, preserve fixed constraints, propose a cohesive direction, generate a realistic concept preview, and separate styling inspiration from construction guidance.\\n\\nFor the first visible response:\\n- Make the makeover feel exciting but low-commitment, with concrete value around testing a style, reusing existing pieces, and seeing a visual before-and-after.\\n- Do not assume the user owns a room, wants to renovate, has a particular budget, or likes the style shown in the creative.\\n- Let the continuation choices offer a style preview, a refresh using current furniture, and a color-and-layout concept.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"mini_me_world\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Roman Hindi. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, language preference, or creative style.\\n\\nCampaign key: mini_me_world\\nCreative theme: transforming an everyday photo into a playful social-media-style scene populated by tiny 3D versions of the person that wave, play, copy the pose, and interact naturally with the original setting.\\nDemonstrated request: turn a photo into a \\\"Mini Me\\\" world with depth, movement, realistic shadows, a soft aesthetic, and a short sentimental title.\\nUseful workflow for later turns: gather one photo, preserve the person's identity and original scene, choose a playful or emotional direction, then generate a cohesive miniature-character composition.\\n\\nFor the first visible response:\\n- Make the transformation feel fun and easy, with concrete value around preserving the original photo, choosing the Mini Me interactions, and creating a shareable result.\\n- Do not assume the user has uploaded a photo, wants a sentimental style, or resembles the featured subject.\\n- Let the continuation choices offer a playful Mini Me scene, a different mood, and a story-ready visual.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"national_team_match_analysis\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, country, favorite team, football knowledge, or current plans.\\n\\nCampaign key: national_team_match_analysis\\nCreative theme: understanding a national team's upcoming opponents and what it would need to do well in each matchup.\\nDemonstrated request: identify the supported national team, analyze each opponent this month, and explain practical paths to winning.\\nUseful workflow for later turns: identify the team and timeframe, browse for the current schedule and squad context, compare opponent strengths and weaknesses, and summarize tactical priorities with appropriate uncertainty.\\n\\nFor the first visible response:\\n- Make match analysis feel current and useful, with concrete value around opponent scouting, tactical keys, and a concise tournament outlook.\\n- Do not assume which team the user supports or invent fixtures, squads, injuries, or current form.\\n- Let the continuation choices offer an opponent-by-opponent preview, tactical keys, and a concise team outlook.\\n- Once the user identifies the team, browse before making current factual claims.\\n- If the user changes topics later, help normally.\",\"enabled\":true},\"restaurant_language_practice\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's nationality, travel plans, language level, location, or durable interests.\\n\\nCampaign key: restaurant_language_practice\\nCreative theme: practicing a short foreign-language phrase for a real restaurant interaction.\\nDemonstrated request: \\\"スペイン語を練習したいんだけど、レストランで「美味しい食事をありがとう」ってどうやって言えばいい？\\\"\\nUseful workflow for later turns: choose a real-life situation and target language, teach one natural phrase with pronunciation and nuance, rehearse a short exchange, then expand only if useful.\\n\\nFor the first visible response:\\n- Make practical language practice feel approachable, with concrete value around natural phrasing, pronunciation, and a short role-play.\\n- Do not assume the user is learning Spanish, going to a restaurant, traveling, or has any particular proficiency.\\n- Let the continuation choices offer one useful phrase, a tiny role-play, and a different everyday situation.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true}}},\"is_device_based\":true,\"passed\":false},\"1355628363\":{\"name\":\"1355628363\",\"rule_id\":\"6EkzgQkSDT4MxFNtb5sHlF:100.00:5-6EkzgOFQbAViegfxzXx42D\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"prompts\":[{\"body\":\"Create a bright text-light mango tasting mat with simple sections for aroma, sweetness, texture and favourite, leaving labels blank.\",\"title\":\"Make a mango tasting mat\"},{\"body\":\"Create a text-light vertical backdrop for a music Reel. Use lively abstract shapes, no platform logos, and leave empty space for my caption.\",\"title\":\"Create a music Reel backdrop\"},{\"title\":\"Map train booking choices\",\"body\":\"Create a simple train ticket status flowchart with icons for CNF, RAC, WL and Tatkal. Keep labels short and editable.\"},{\"title\":\"Build a reading routine\",\"body\":\"Help me build a 20-minute reading routine. Ask me one question about when I can read, then suggest a first-week plan.\"},{\"body\":\"Teach me how to plan a short trip from scratch. Ask one question about destination and dates, then build a simple itinerary outline.\",\"title\":\"Learn to plan a short trip\"},{\"title\":\"Get into Wimbledon gently\",\"body\":\"Give me a fun Wimbledon 2026 primer: what makes grass-court tennis different, who to notice, and how to sound less lost.\"},{\"body\":\"Check the current Wimbledon schedule and suggest one match to follow from India, with the likely match time and one story to watch.\",\"title\":\"Pick a Wimbledon match\"},{\"title\":\"Polish a WhatsApp message\",\"body\":\"I need to send a tricky WhatsApp message. Ask me to paste it and say who it is for, then make it polite and natural.\"},{\"title\":\"Turn revision into a game\",\"body\":\"Make my unit-test revision feel like a game. Ask my subject first, then give a 20-minute plan with quick rounds.\"},{\"title\":\"Plan a rainproof commute\",\"body\":\"Make a rainy-day commute game plan. Ask my city and route first, then suggest backup transport, timing buffers and what to pack.\"},{\"body\":\"Give me a fun, no-jargon catch-up on the Women’s T20 World Cup, with India’s path, key players to notice, and one thing to watch today.\",\"title\":\"Make a cricket catch-up card\"},{\"body\":\"Build a light India vs England watch plan for July: match reminders, snack breaks, and a simple way to follow if I miss overs.\",\"title\":\"Plan a late-night cricket watch\"},{\"title\":\"Build a kirana restock list\",\"body\":\"Make a monthly kirana restock list. Ask my household size first, then organise staples, cleaning items and quick top-ups.\"},{\"body\":\"Explain today’s India monsoon update in plain English, including what normal, deficit and warning colours mean.\",\"title\":\"Read monsoon updates better\"},{\"title\":\"Build a monsoon travel buffer\",\"body\":\"Help me plan a monsoon journey with buffers for delays. Ask my city pair and travel mode, then make a practical backup plan.\"},{\"body\":\"Make a spoiler-free debate guide for a current Indian film my friends have seen. Ask the film name, then give talking points.\",\"title\":\"Host a spoiler-free film chat\"},{\"title\":\"Plan your Wimbledon viewing\",\"body\":\"Check the Wimbledon 2026 schedule and make me a simple IST viewing plan for the first week. Ask which players I care about.\"},{\"title\":\"Make a study quest map\",\"body\":\"Create a simple study quest map with 7 checkpoints, icons and blank labels. Ask me the subject first, then give label text separately.\"},{\"title\":\"Make a pantry check poster\",\"body\":\"Create a text-light pantry label-check poster with icons for MRP, expiry, ingredients, veg or non-veg symbol and storage.\"},{\"title\":\"Draw a rainy entryway\",\"body\":\"Create a simple text-light rainy entryway layout for an Indian flat: shoe zone, umbrella spot, drying mat and hooks. No brand names.\"},{\"title\":\"Get documents ready online\",\"body\":\"Help me prepare a DigiLocker-ready document set for admissions or a government service. Ask which task first.\"},{\"title\":\"Fix monsoon laundry\",\"body\":\"Make a monsoon laundry rota for a small home where clothes dry indoors. Include smell prevention, rainy-day backup and what to wash first.\"},{\"title\":\"Prepare Passport Seva papers\",\"body\":\"Help me prepare for a Passport Seva appointment. Check official document guidance and ask one question about my application type.\"},{\"title\":\"Set up DigiLocker basics\",\"body\":\"Explain DigiLocker in everyday terms and help me plan which documents to fetch, upload, or carry as originals.\"},{\"body\":\"Teach me 8 polite phrases for an auto or cab ride. Ask my city or language first, then give pronunciation help.\",\"title\":\"Learn ride phrases\"},{\"body\":\"Practise a 5-minute small-talk scene with me. Ask the setting first, then play the other person and keep it light.\",\"title\":\"Practise small talk lightly\"},{\"title\":\"Learn a topic with examples\",\"body\":\"Teach me a difficult topic using everyday examples. Ask me the topic first, then build a 10-minute lesson.\"},{\"title\":\"Pack a better tiffin\",\"body\":\"Plan 3 spill-proof tiffin ideas. Ask what I eat and whether I can reheat first, then keep it practical.\"},{\"body\":\"Make a first hostel packing list for India’s monsoon months. Ask my city and hostel rules first, then group must-haves and nice-to-haves.\",\"title\":\"Pack for hostel in the rains\"},{\"title\":\"Review UPI AutoPay safely\",\"body\":\"Teach me how UPI AutoPay mandates work and give me a safe way to review subscriptions without sharing account details.\"},{\"body\":\"Practise a short meeting update with me. Give me a simple structure, then ask one question and correct my answer gently.\",\"title\":\"Practise a meeting update\"},{\"title\":\"Draw a hostel packing map\",\"body\":\"Create a text-light packing map for a monsoon hostel or PG room: bedding, documents, footwear, laundry and desk. Use simple icons.\"},{\"body\":\"Help me make a practical monsoon plan for today: commute, footwear, laundry and bag essentials. Ask for my city first.\",\"title\":\"Rain-proof my day\"},{\"body\":\"Explain the young players people are discussing in India’s Ireland and England T20Is. Keep it beginner-friendly and avoid hype.\",\"title\":\"Understand the new India names\"},{\"body\":\"Write a clear, polite message to request a UPI split for a group expense. Keep it short and include a line asking people to verify payee name.\",\"title\":\"Share a UPI split politely\"},{\"body\":\"Make me a simple FIFA World Cup watch plan for India time. Ask which teams I follow, then suggest matches, snacks and a sleep-friendly routine.\",\"title\":\"Plan a World Cup night\"},{\"title\":\"Create a chore wheel\",\"body\":\"Create a simple chore wheel with household task icons and blank name spaces. Ask how many people should fit on it first.\"},{\"title\":\"Pack for monsoon commutes\",\"body\":\"Build a monsoon commute kit for my city and travel mode. Ask one question if needed, then group items as must-carry and optional.\"},{\"title\":\"Build a rainy commute playlist\",\"body\":\"Use current India music charts to build a 7-song playlist theme for a rainy commute. Avoid explicit lyrics unless I ask.\"},{\"body\":\"Create a text-light match-night scoreboard image for the Women’s T20 World Cup. Keep spaces blank for teams, runs, snacks, and MVP.\",\"title\":\"Create a match-night scoreboard\"},{\"title\":\"Build a smarter grocery run\",\"body\":\"Make a grocery list that prevents random extras. Ask what I’m cooking this week, then group items by store section.\"},{\"title\":\"Decode my train status\",\"body\":\"I’ll paste only my ticket status, not my full PNR. Explain CNF, RAC or WL and tell me the next sensible check.\"},{\"title\":\"Cook from fridge leftovers\",\"body\":\"Help me turn fridge leftovers into an Indian-style meal. I can upload a photo or list what I have.\"},{\"title\":\"Plan a short trip in India\",\"body\":\"Help plan a 2–3 day trip in India. First ask my starting city and rough budget, then suggest practical options.\"},{\"body\":\"Pick a song currently high on YouTube India and explain its hook, structure and replay value without quoting lyrics.\",\"title\":\"Break down a charting song\"},{\"body\":\"Teach me pressure cooker basics for dal, rice and chana, including whistles, soaking and safety checks.\",\"title\":\"Learn cooker timing basics\"},{\"title\":\"Storyboard a song hook\",\"body\":\"Create a 6-frame, text-light storyboard template for explaining why a current YouTube India song hook works, with no lyrics or artist likenesses.\"},{\"body\":\"Give me a 30-minute game plan to sort household papers into keep, act and file piles. Ask what kind of papers I have first.\",\"title\":\"Sort papers without panic\"},{\"title\":\"Pick a Van Mahotsav sapling\",\"body\":\"Help me pick one low-maintenance native sapling for Van Mahotsav. Ask my city and planting space, then give care steps.\"},{\"body\":\"Explain the FIFA World Cup knockout format for an India viewer, including how extra time and penalties work.\",\"title\":\"Learn the World Cup knockout\"},{\"title\":\"Make a match-night tracker\",\"body\":\"Create a text-light FIFA World Cup match-night tracker with blank team slots, score spaces, and room for IST timings.\"},{\"title\":\"Decode a talked-about squad pick\",\"body\":\"Give me a quick profile of a current India squad pick being searched a lot. Cover role, recent context and what to watch for.\"},{\"body\":\"Run a mock interview like ping-pong. Ask my role, then give one question at a time with a short coaching note after each answer.\",\"title\":\"Play mock interview ping-pong\"},{\"body\":\"Build a 5-day school or office tiffin rotation using Indian staples. Ask one question about dietary limits before suggesting.\",\"title\":\"Plan a tiffin rotation\"},{\"title\":\"See field positions clearly\",\"body\":\"Create a simple T20 fielding map for a new cricket fan using dots and zones, with any position names listed outside the image.\"},{\"body\":\"Explain Form 16, AIS, 26AS and ITR in simple terms for AY 2026-27. Ask one question only if you need my income type.\",\"title\":\"Understand Form 16 and AIS\"},{\"title\":\"Sort tiny UPI payments\",\"body\":\"Help me make a tiny-payment routine for chai, autos and kirana. Check current UPI Lite rules and remind me not to share PINs.\"},{\"title\":\"Decode holiday types\",\"body\":\"Explain gazetted, restricted and state holidays in India using the 2026 calendar. Give a simple rule for checking office or school closures.\"},{\"title\":\"Make chores less boring\",\"body\":\"Turn weekly chores into a fair, playful rota. Ask how many people are sharing, then suggest roles, swaps and a 10-minute reset.\"},{\"title\":\"Create a rainy-day snack board\",\"body\":\"Create a cosy, text-light image of an Indian monsoon snack board with chai, rain cues and blank label spaces.\"},{\"title\":\"Choose an OTT trailer night\",\"body\":\"Find three current India OTT trailers worth sampling tonight, then make a playful 30-minute no-spoiler watch plan.\"},{\"title\":\"Make a mini tennis bracket\",\"body\":\"Make a tiny Wimbledon bracket game I can use with friends, simple scoring, no expert knowledge needed.\"},{\"body\":\"Help me turn leftovers into dinner. Ask me for a fridge photo or ingredient list, then suggest 3 playful options with simple steps.\",\"title\":\"Remix leftovers into dinner\"},{\"body\":\"Create a simple tiffin idea wheel with icons for grain, protein, veg, fruit and snack. Use blank labels, no brand names.\",\"title\":\"Make a tiffin idea wheel\"},{\"title\":\"Discuss Kargil respectfully\",\"body\":\"Help me discuss Kargil Vijay Diwas in a balanced way for a study group. Give 5 questions that focus on history, courage and evidence.\"},{\"title\":\"Create a tennis bingo card\",\"body\":\"Create a text-light Wimbledon bingo card image for a home watch. Use simple icons and blank squares, no player likenesses or logos.\"},{\"body\":\"Create a simple layout sketch to make my desk or room easier to use. Ask for a photo or short description first.\",\"title\":\"Sketch a better room layout\"},{\"body\":\"Suggest a playful mango tasting at home for National Mango Day. Include ways to compare flavour, texture, aroma and use.\",\"title\":\"Host a mango tasting\"},{\"title\":\"Make a tennis score card\",\"body\":\"Create a clean, text-light tennis scorecard image for Wimbledon watching. Leave blanks for player names and sets. No logos.\"},{\"title\":\"Make a rainy commute card\",\"body\":\"Create a simple rainy-day commute safety card for India, using icons only and no location-specific claims.\"},{\"body\":\"Create a simple 6-panel image storyboard for a 20-second everyday Reel. Keep it text-light and use blank caption boxes.\",\"title\":\"Create a Reel storyboard\"},{\"title\":\"Reset my desk like a game\",\"body\":\"Help me reset my desk in 15 minutes. Ask me for a photo or short description, then turn it into 3 quick rounds.\"},{\"body\":\"Help me write a polite message to split a UPI payment. Ask what was paid and the amount, then make it clear without sounding awkward.\",\"title\":\"Settle a UPI split politely\"},{\"body\":\"Give me a friendly 5-minute guide to Puri Rath Yatra, including key words I’ll hear and respectful visitor basics.\",\"title\":\"Understand Rath Yatra quickly\"},{\"body\":\"Make a simple IST watch plan for the next FIFA World Cup 2026 matches I care about. Ask which teams I follow, then keep it realistic for workdays.\",\"title\":\"Plan a late-night World Cup watch\"},{\"body\":\"Create a text-light visual layout for a monsoon drying corner at home. Ask one question about space if needed.\",\"title\":\"Design a drying corner\"},{\"body\":\"Help me choose a reliable live-sport setup for home: TV, app or backup data. Ask what I’m watching and what devices I have.\",\"title\":\"Fix my match stream setup\"},{\"title\":\"Create a Rath Yatra story map\",\"body\":\"Create a simple text-light illustration of Puri Rath Yatra’s temple-to-Gundicha journey, with blank labels I can fill in.\"},{\"body\":\"Practise an interview for my role. Ask one question at a time, wait for my answer, then give brief feedback. First ask my role.\",\"title\":\"Practise interview answers\"},{\"title\":\"Write a service message\",\"body\":\"Help me write a short message to a driver, shop or technician in English and one Indian language I choose. Ask the language first.\"},{\"title\":\"Pick a cinema plan\",\"body\":\"Help me choose from current Hindi and pan-India theatrical releases. Ask my city and mood, then make a simple cinema plan.\"},{\"body\":\"Explain BGMI terms like ping, desync, FPS and server lag with simple examples a casual player would get.\",\"title\":\"Learn BGMI lag terms\"},{\"title\":\"Make a World Cup match tracker\",\"body\":\"Create a text-light World Cup match tracker image I can print. Use blank slots for teams, dates and predictions, with a clean football-night feel.\"},{\"body\":\"Show me how moon-sighting based holidays can shift on calendars. Use Muharram 2026 as the example and give a simple planning rule.\",\"title\":\"Check moon-sighting dates\"},{\"title\":\"Follow India Women with context\",\"body\":\"Make a spoiler-light guide to India Women at the ICC Women’s T20 World Cup 2026. Include upcoming matches, storylines and terms to know.\"},{\"title\":\"Create a match-night score card\",\"body\":\"Create a text-light printable score card for a FIFA World Cup watch night, with blank spaces for teams, predictions, and snacks.\"},{\"title\":\"Plan a Rath Yatra day\",\"body\":\"Help me plan a safe Rath Yatra day in Puri. Ask my travel date and starting point, then make a realistic route and packing plan.\"},{\"body\":\"Create a simple visual card for structuring interview answers using four blank sections and small icons. Keep text minimal.\",\"title\":\"Make an interview answer card\"},{\"title\":\"Plan a rain-safe commute\",\"body\":\"Help me plan a monsoon commute. Ask my city and usual route, then suggest what to check, carry and avoid today.\"},{\"title\":\"Plan a week of simple meals\",\"body\":\"Plan a week of simple meals. Ask one question about what I eat or have at home, then give meals and a shopping list for an Indian kitchen.\"},{\"body\":\"Create a clean weekly planner image with blank day blocks, priority space and simple symbols. Keep it mostly text-free.\",\"title\":\"Make a weekly planner page\"},{\"title\":\"Make a tiffin menu card\",\"body\":\"Create a text-light weekly tiffin menu card with simple food icons and blank spaces I can fill in.\"},{\"title\":\"Find a charting song angle\",\"body\":\"Use India’s current YouTube music charts to suggest one song-based Reel or Shorts idea. Keep it lyric-safe and easy to film.\"},{\"title\":\"Plan easy lunchbox ideas\",\"body\":\"Help me plan easy lunchbox ideas using what I usually buy. Ask my main staples, then keep it low-effort.\"},{\"title\":\"Make a water-check reminder\",\"body\":\"Create a text-light reminder card for a weekly stagnant-water check. Use simple home icons, no scary imagery.\"},{\"body\":\"Use current India YouTube music trends to build a no-ski